<odoo>
    <record id="view_payment_provider_form_inherit_credentials" model="ir.ui.view">
        <field name="name">payment.provider.form.inherit.credentials.fields</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>  <!-- inherit from original view -->
        <field name="arch" type="xml">
            <!-- XPath to target the 'Credentials' page/tab -->
            <xpath expr="//page[@name='credentials']" position="inside">
                <group>
                    <field name="maya_public_key" password="True"/>
                    <field name="maya_secret_key" password="True"/>
                    <field name="maya_api_timeout"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
