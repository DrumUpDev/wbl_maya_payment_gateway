<odoo>
    <record id="view_maya_refund_wizard_form" model="ir.ui.view">
        <field name="name">maya.refund.amount.wizard.form</field>
        <field name="model">maya.refund.amount.wizard</field>
        <field name="arch" type="xml">
            <form string="Refund">
                <group>
                    <field name="refund_amount"/>
<!--                    <field name="currency_id" readonly="1"/>-->
                </group>
                <footer>
                    <button string="Refund" type="object" name="confirm_refund" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
